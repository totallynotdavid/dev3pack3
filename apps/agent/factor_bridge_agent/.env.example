# =========================================================
# Seleccion de proveedor de modelo
# Valores: openrouter | openrouter_claude | huggingface
# =========================================================
MODEL_PROVIDER=openrouter

# =========================================================
# OpenRouter — llama-3.3-70b gratis o claude-sonnet-4.6 con credito
# Obtén tu key en: https://openrouter.ai/keys
# =========================================================
OPENROUTER_API_KEY=tu_api_key_de_openrouter_aqui

# =========================================================
# Hugging Face — Meta-Llama-3.1-8B-Instruct (gratis con token HF)
# Crea tu token en: https://huggingface.co/settings/tokens
# =========================================================
HUGGINGFACE_API_KEY=tu_token_hf_aqui

# =========================================================
# Modo: Google AI Studio (alternativa — descomenta si usas Gemini)
# =========================================================
# GOOGLE_GENAI_USE_VERTEXAI=FALSE
# GOOGLE_API_KEY=tu_api_key_de_google_ai_studio_aqui

# =========================================================
# APIs externas Perú (opcionales - el agente funciona con mocks si faltan)
# =========================================================
# Token gratuito: https://apis.net.pe
APIS_NET_PE_TOKEN=

# Token: https://api.decolecta.com
DECOLECTA_TOKEN=
