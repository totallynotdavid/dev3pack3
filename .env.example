# Web runtime (required)
POSTGRES_URL=postgresql://user:password@localhost:5432/sentinel
NEXT_PUBLIC_SOLANA_CLUSTER=devnet
NEXT_PUBLIC_AGENT_API_URL=https://factor-bridge-agent-197950168142.us-central1.run.app/query
NEXT_PUBLIC_STOREFRONT_URL=http://localhost:3000

# Clerk authentication (required by web auth)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
